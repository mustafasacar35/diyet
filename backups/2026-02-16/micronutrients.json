  {
    "id": "acc50ed9-b618-404a-80e8-d920946551d3",
    "name": "b12",
    "unit": "pg/mL",
    "default_min": 200,
    "default_max": 900,
    "created_at": "2026-01-29T08:26:15.873934+00:00",
    "category": "mikrobesin",
    "compatible_keywords": [
      {
        "info": "[Destekleyici]: Yüksek miktarda B12 vitamini içerir ve vücudun ihtiyacını karşılamaya yardımcı olur.; Haftada 1-2 kez 100-150 gram tüketilebilir.",
        "keyword": "Karaciğer",
        "match_type": "both"
      },
      {
        "info": "[Destekleyici]: B12 vitamini açısından zengindir ve düzenli tüketimi B12 seviyelerini artırır.; Haftada 2-3 kez 150-200 gram tüketilebilir.",
        "keyword": "Balık (Somon, Ton)",
        "match_type": "both"
      },
      {
        "info": "[Destekleyici]: B12 vitamini içerir ve özellikle sarısı B12 kaynağıdır. Aynı zamanda biotin içerdiği için B12 emilimini destekler.; Günde 1-2 adet tüketilebilir.",
        "keyword": "Yumurta",
        "match_type": "both"
      },
      {
        "info": "[Destekleyici]: B12 vitamini içerir ve kalsiyum ile birlikte alındığında emilimi artar.; Günde 1-2 porsiyon süt, yoğurt veya peynir tüketilebilir.",
        "keyword": "Süt ve süt ürünleri",
        "match_type": "both"
      }
    ],
    "incompatible_keywords": [
      {
        "info": "Metformin kullanan bireylerin düzenli olarak B12 seviyelerini kontrol ettirmesi ve gerekirse takviye alması önerilir.",
        "keyword": "Metformin",
        "warning": "Metformin, B12 vitamininin ince bağırsaktan emilimini azaltarak B12 eksikliğine neden olabilir.",
        "match_type": "both"
      },
      {
        "info": "Uzun süreli PPI kullanımı gerekiyorsa, B12 takviyesi alınması düşünülebilir.",
        "keyword": "Proton Pompa İnhibitörleri (PPI)",
        "warning": "PPI'lar mide asidini azaltarak B12'nin proteinlerden ayrılmasını ve emilimini zorlaştırır.",
        "match_type": "both"
      },
      {
        "info": "Uzun süreli H2 bloker kullanımı gerekiyorsa, B12 takviyesi alınması düşünülebilir.",
        "keyword": "Histamin H2 Reseptör Antagonistleri",
        "warning": "Mide asidini azaltarak B12'nin proteinlerden ayrılmasını ve emilimini zorlaştırır.",
        "match_type": "both"
      },
      {
        "info": "Alkol tüketimi sınırlandırılmalı veya tamamen bırakılmalıdır. B12 takviyesi alınması faydalı olabilir.",
        "keyword": "Alkol",
        "warning": "Alkol, mide ve bağırsak mukozasına zarar vererek B12 emilimini azaltır ve B12 depolarını tüketir.",
        "match_type": "both"
      },
      {
        "info": "Kahve tüketimi ile B12 takviyesi veya B12 içeren besinlerin tüketimi arasında en az 2 saat bırakılması önerilir.",
        "keyword": "Kahve",
        "warning": "Kahve, içeriğindeki bazı bileşenler nedeniyle B12 vitamininin emilimini azaltabilir.",
        "match_type": "both"
      }
    ]
  },
